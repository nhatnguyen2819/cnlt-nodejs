<%- include('layouts/header', { title: title }) %>
<%- include('layouts/navbar') %>

<main>
    <h1>Danh sách bài viết</h1>
    <p class="subtitle">Quản lý bài viết: tạo, xem, sửa, xóa</p>
    <a href="/blogposts/new" class="btn">Thêm bài viết mới</a>
    <% if (posts && posts.length > 0) { %>
        <div class="post-list">
            <% posts.forEach(post => { %>
                <div class="post-item">
                    <h2><a href="/blogposts/<%= post._id %>"><%= post.title %></a></h2>
                    <% if (post.image) { %>
                        <img src="/images/<%= post.image %>" alt="<%= post.title %>" style="max-width:200px; display:block; margin-bottom:10px;" />
                    <% } %>
                    <p><%= post.body.length > 150 ? post.body.substring(0, 150) + '...' : post.body %></p>
                    <div class="post-meta">Tạo lúc <%= post.createdAt.toLocaleString() %></div>
                    <div class="actions">
                        <a href="/blogposts/<%= post._id %>" class="btn">Xem</a>
                        <a href="/blogposts/edit/<%= post._id %>" class="btn">Sửa</a>
                        <form action="/blogposts/delete/<%= post._id %>" method="POST" style="display:inline;">
                            <button class="btn danger" type="submit">Xóa</button>
                        </form>
                    </div>
                </div>
                <hr>
            <% }) %>
        </div>
    <% } else { %>
        <p>Chưa có bài viết nào. <a href="/blogposts/new">Tạo bài mới</a>.</p>
    <% } %>
</main>

<%- include('layouts/footer') %>
