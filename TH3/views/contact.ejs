<%- include('layouts/header') %>
<%- include('layouts/navbar') %>

<main>
    <h1>Liên hệ với tôi</h1>
    <div class="contact-container">
        <div class="contact-info">
            <p>Bạn có thể kết nối với tôi qua các kênh sau:</p>
            <ul>
                <li><strong>Email:</strong> Nguyen@example.com </li>
                <li><strong>Phone:</strong> +84 978 307 577 </li>
                <li><strong>Location:</strong> Quy Nhơn City, Vietnam</li>
                <li><strong>GitHub:</strong> https://github.com/nhatnguyen2819</li>
            </ul>
            <p>Hoặc gửi tin nhắn trực tiếp qua form:</p>
        </div>

        <form class="contact-form">
            <div class="form-group">
                <label for="name">Họ tên:</label>
                <input type="text" id="name" name="name" required>
            </div>
            <div class="form-group">
                <label for="email">Email:</label>
                <input type="email" id="email" name="email" required>
            </div>
            <div class="form-group">
                <label for="message">Nội dung:</label>
                <textarea id="message" name="message" rows="5" required></textarea>
            </div>
            <button type="submit" class="btn">Gửi tin nhắn</button>
        </form>
    </div>
</main>

<%- include('layouts/footer') %>